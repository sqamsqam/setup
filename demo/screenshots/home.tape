Set Shell "bash"
Set Width 1000
Set Height 650
Set FontSize 16
Set Padding 12
Set Theme "Dracula"
Set WindowBar "Colorful"
Set WindowBarSize 32
Set BorderRadius 8
Set TypingSpeed 20ms

Type "./bin/setup-linux-amd64 --demo"
Enter
Wait+Screen /Ubuntu Dev Instance Setup/
Sleep 700ms
Screenshot "docs/assets/screenshots/home.png"
Sleep 500ms
Ctrl+C
Sleep 300ms
